{
    "name": "php-nil/kernel",
    "description": "Nil Kernel - A lightweight PHP kernel built on Symfony components",
    "keywords": ["nil", "kernel", "framework", "symfony"],
    "license": "MIT",
    "require": {
        "php": ">=8.2.0",
        "symfony/error-handler": "^8.0",
        "symfony/event-dispatcher": "^8.0",
        "symfony/http-foundation": "^8.0",
        "symfony/routing": "^8.0",
        "symfony/console": "^8.0",
        "symfony/cache": "^8.0",
        "symfony/contracts": "^3.6",
        "doctrine/dbal": "^4.4",
        "monolog/monolog": "^3.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nil\\Kernel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nil\\Kernel\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
